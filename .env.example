# Frontend (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# Legacy alias (also accepted by the app):
# VITE_SUPABASE_ANON_KEY=your_publishable_key
VITE_ADMIN_EMAIL=jeremy@hoppytech.com

# Server (Vercel API routes — any one service-role key name works)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_secret_key
# Legacy aliases also supported by api/_lib/supabase-admin.js:
# SUPABASE_SECRET_KEY=
# VITE_SUPABASE_SECRET_KEY=  (avoid — exposes secret naming to client builds)

RESEND_API_KEY=
RESEND_FROM=Hoppy Tech Intake <hello@hoppytech.com>
RESEND_TO=jeremy@hoppytech.com
RESEND_DESIGN_TO=bella@hoppytech.com
# All contact/referral/chatbot intake emails are sent to both addresses above.
ADMIN_EMAIL=jeremy@hoppytech.com
GEMINI_API_KEY=
GITHUB_TOKEN=
PORT=3001
